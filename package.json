{
  "name": "ai-gym-trainer-bot",
  "version": "2.0.0",
  "description": "AI Gym Trainer with Telegram Bot – Full workout schedule, form analysis, and video recording",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "bot": "node bot.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "setup": "npm install && mkdir -p public uploads logs models",
    "docker:build": "docker build -t gym-trainer .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/uploads:/app/uploads -v $(pwd)/logs:/app/logs gym-trainer"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.64.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "telegram-bot",
    "gym",
    "fitness",
    "workout",
    "exercise",
    "ai-trainer",
    "pose-detection",
    "mediapipe",
    "mini-app"
  ],
  "author": "AI Gym Trainer",
  "license": "MIT"
}
